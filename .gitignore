# Swift SDK test fixtures: small, deterministic, source-of-truth for parity
# tests; must be committed so CI / fresh clones can run them. The earlier
# *.bin and *.wav patterns above otherwise filter them out.
!swift/Tests/TinyAudioTests/Fixtures/*.bin
!swift/Tests/TinyAudioTests/Fixtures/*.wav

# Silero VAD Core ML model: compiled once via scripts/convert_silero_vad.py
# and shipped as a SwiftPM resource. The *.bin rule above would filter the
# weights file inside the .mlpackage bundle, so we un-ignore it here.
!swift/Sources/TinyAudio/Resources/silero_vad.mlpackage/
!swift/Sources/TinyAudio/Resources/silero_vad.mlpackage/**

# TinyAudio SDK bundled model weights — generated locally by
# `ta mlx build-bundle --projector <repo>` (see swift/Sources/TinyAudio/
# Resources/Model/README.md). The dir itself stays tracked via the
# README so SwiftPM's `.copy("Resources/Model")` rule still resolves.
swift/Sources/TinyAudio/Resources/Model/*
!swift/Sources/TinyAudio/Resources/Model/README.md

